---
interface Props {
  title: string;
  description?: string;
  siteName: string;
}

const { title, description, siteName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="FolioCMS" />
    {description && <meta name="description" content={description} />}
    <title>{title} — {siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-wrapper">
      <header>
        <a href="/" class="site-name">{siteName}</a>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>Powered by <a href="https://github.com/srmdn/foliocms">FolioCMS</a></p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
